{
  "name": "@kado/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "dev": "expo start --dev-client",
    "dev:lan": "expo start --dev-client --host lan",
    "dev:tunnel": "expo start --dev-client --host tunnel",
    "dev:go": "expo start",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:dev:android": "eas build --profile development --platform android",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:production": "eas build --profile production --platform all",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.0",
    "@expo/log-box": "^55.0.8",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@kado/contracts": "0.1.0",
    "@kado/domain": "0.1.0",
    "@kado/ui": "0.1.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "convex": "^1.32.0",
    "expo": "~55.0.9",
    "expo-auth-session": "~55.0.10",
    "expo-camera": "~55.0.11",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.9",
    "expo-dev-client": "~55.0.19",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-image-manipulator": "~55.0.13",
    "expo-image-picker": "~55.0.14",
    "expo-linking": "~55.0.9",
    "expo-notifications": "~55.0.15",
    "expo-router": "~55.0.8",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.10",
    "lucide-react-native": "^1.6.0",
    "nativewind": "^4.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "^0.7.2",
    "semver": "^7.7.4",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~55.0.9",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  }
}
