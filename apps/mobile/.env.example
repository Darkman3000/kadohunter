# Metro monorepo: keep 1 so /index.bundle works for Expo web and default dev URLs.
EXPO_NO_METRO_WORKSPACE_ROOT=1

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_CONVEX_URL=

# For Convex CLI / auth — set on Convex deployment (Dashboard or root .env.local for `npx convex dev`)
# CLERK_JWT_ISSUER_DOMAIN=https://YOUR_INSTANCE.clerk.accounts.dev
